rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function role() { return getProfile().role; }
    function isAdmin() { return role() == 'admin'; }
    // isCoach() and isLeagueManager() are retained for paths that have no
    // resource-scoped access list to check against (events, players, invites).
    function isCoach() { return role() == 'coach'; }
    function isLeagueManager() { return role() == 'league_manager'; }

    // ── Phase 2: resource-scoped access helpers ───────────────────────────
    // These check the denormalized access lists backfilled in Phase 1.
    // No cross-doc profile read required — eliminates SEC-16 TOCTOU race.

    // Returns true if the caller is a coach of this team.
    // SEC-55 backfill confirmed complete on all environments (2026-04-12) —
    // legacy coachId scalar fallback removed.
    function isCoachOfTeam(teamData) {
      return teamData.coachIds is list && teamData.coachIds.hasAny([request.auth.uid]);
    }

    // Returns true if the caller's UID is in the league document's managerIds array.
    function isManagerOfLeague(leagueData) {
      return leagueData.managerIds is list && leagueData.managerIds.hasAny([request.auth.uid]);
    }

    // Cross-doc read variant for league subcollections where the league document
    // is not the match resource (e.g. /leagues/{leagueId}/seasons/{seasonId}).
    // Single get() call — avoids billing two reads per evaluation.
    function isManagerOfLeagueById(leagueId) {
      return isManagerOfLeague(
        get(/databases/$(database)/documents/leagues/$(leagueId)).data
      );
    }

    // Returns true if the caller is a league manager of the league that manages
    // the given team. Uses _managedLeagueId (set by addTeamToLeague) as the link.
    // Falls back gracefully if the field is absent — returns false (not an error).
    function isManagerOfTeam(teamData) {
      return isLeagueManager()
        && teamData._managedLeagueId is string
        && isManagerOfLeagueById(teamData._managedLeagueId);
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == uid || isAdmin();
      // Self-update: users may update their own profile fields but must not
      // touch uid or memberships (admin-only), and must not escalate their
      // top-level role to admin or league_manager.
      // mustChangePassword may only be cleared (set to false) by the user
      // themselves — setting it to true is admin-only.
      allow update: if (request.auth.uid == uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['uid', 'memberships'])
          && !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['mustChangePassword'])
               && request.resource.data.mustChangePassword == true)
          && !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
               && ['admin', 'league_manager', 'coach'].hasAny([request.resource.data.role]))
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() >= 1
          && request.resource.data.displayName.size() <= 100)
        || isAdmin()
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teamId']) &&
          exists(/databases/$(database)/documents/teams/$(request.resource.data.teamId)) &&
          isCoachOfTeam(
            get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data
          )
        );
      allow delete: if isAdmin();

      match /notifications/{notifId} {
        allow read, write: if request.auth.uid == uid;
      }
      match /config/{doc} {
        allow read, write: if request.auth.uid == uid;
      }
      match /venues/{venueId} {
        allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow create: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.ownerUid == request.auth.uid;
        allow update: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.ownerUid == resource.data.ownerUid;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
      match /consents/{type} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    // NOTE (SEC-29): Firestore rules unit tests for the field-level restrictions below
    // are not yet implemented — the project has no @firebase/rules-unit-testing setup.
    // When that infrastructure is added, cover at minimum:
    //   - Coach updates team name → allowed
    //   - Coach updates team coachIds → permission-denied
    //   - Coach updates team name + coachIds simultaneously → permission-denied
    //   - LM updates league name/season → allowed
    //   - LM updates league managerIds → permission-denied
    //   - LM updates league name + managerIds simultaneously → permission-denied
    //   - Admin updates coachIds → allowed
    match /teams/{teamId} {
      allow read: if request.auth != null;
      // SEC-52: coaches/LMs may not create a team with leagueIds pre-set —
      // league assignment is an LM-gated update. Prevents bypassing SEC-36.
      allow create: if isAdmin()
        || (
          (isCoach() || isLeagueManager())
          && !('leagueIds' in request.resource.data)
          && !('_managedLeagueId' in request.resource.data)
        );
      allow delete: if isAdmin();
      // Phase 2: use coachIds access list instead of profile.leagueId cross-doc read.
      // SEC-29: non-admin writes may not touch access-control fields (coachIds,
      // coachId, createdBy).  Admins retain unrestricted write access.
      //
      // LM path: the client must supply _managedLeagueId (the league being
      // added/removed) so that rules can do a single get() to verify the LM
      // holds that league's managerIds membership.  Only leagueIds and
      // _managedLeagueId may change in that operation.
      // SEC-35: isLeagueManager() checks the legacy `role` field only — users
      // who became LMs via createLeagueAndBecomeManager or assignScopedRole
      // keep role='coach' at the top level. Use isManagerOfLeague() alone
      // (same fix as SEC-34 for league venues).
      // SEC-36: coaches may not self-assign their team to a league — leagueIds
      // and _managedLeagueId are reserved for the LM path below.
      allow update: if isAdmin()
        || (
          isCoachOfTeam(resource.data)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['coachIds', 'coachId', 'createdBy', 'leagueIds', '_managedLeagueId'])
        )
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['leagueIds', '_managedLeagueId'])
          && '_managedLeagueId' in request.resource.data
          && (request.resource.data.leagueIds.hasAny([request.resource.data._managedLeagueId])
              || resource.data.get('leagueIds', []).hasAny([request.resource.data._managedLeagueId]))
          && isManagerOfLeague(
               get(/databases/$(database)/documents/leagues/$(request.resource.data._managedLeagueId)).data
             )
        );

      // Player availability windows — any team member can read; players/parents write their own,
      // coaches and admins can write any player's record.
      match /availability/{playerId} {
        allow read: if request.auth != null;
        allow write: if isAdmin()
          || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(teamId)).data)
          || (request.auth != null
              && exists(/databases/$(database)/documents/players/$(playerId))
              && get(/databases/$(database)/documents/players/$(playerId)).data.linkedUid == request.auth.uid);
      }

      match /joinRequests/{requestUid} {
        allow create: if request.auth.uid == requestUid;
        allow read: if request.auth.uid == requestUid
          || isAdmin()
          || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(teamId)).data);
        allow update: if isAdmin()
          || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(teamId)).data);
      }

      // Team group chat messages.
      // Read/write: team coach, admin, or any authenticated user whose profile
      // lists this teamId (legacy field). Multi-membership users covered by
      // their profile.teamId or via the coach access list.
      // SEC-64 TODO: migrate to denormalized memberUids array on team doc for full
      // multi-team membership support (legacy teamId field can be stale after transfers).
      match /messages/{messageId} {
        allow read: if request.auth != null
          && (isAdmin()
              || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(teamId)).data)
              || getProfile().get('teamId', '') == teamId);
        // Create only — no updates, no deletes by senders (coaches/admins moderate).
        // SEC-65: text capped at 2000 chars to prevent Firestore DoS via large payloads.
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.teamId == teamId
          && request.resource.data.keys().hasAll(['teamId', 'senderId', 'senderName', 'text', 'createdAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000
          && (isAdmin()
              || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(teamId)).data)
              || getProfile().get('teamId', '') == teamId);
        allow delete: if isAdmin()
          || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(teamId)).data);
      }
    }

    match /players/{playerId} {
      // SEC-48/SEC-50: replaced broad isCoach()/isLeagueManager() with team-scoped
      // isCoachOfTeam() check. Previously any coach or LM could read every player
      // on the platform regardless of team membership.
      // Coaches of the player's team can read; parents/players on the same team can
      // read; a user can always read their own linked player record.
      allow read: if request.auth != null && (
        isAdmin() ||
        resource.data.linkedUid == request.auth.uid ||
        isCoachOfTeam(get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data) ||
        getProfile().teamId == resource.data.teamId
      );
      // SEC-48: scope create to coaches of the target team only.
      // SEC-55 backfill confirmed complete — broad isCoach() fallback removed.
      // LM access is team-scoped via isManagerOfTeam (checks _managedLeagueId).
      allow create: if isAdmin()
        || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data)
        || isManagerOfTeam(get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data);
      allow delete: if isAdmin()
        || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data)
        || isManagerOfTeam(get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data);
      // SEC-57: coach update branch enforces teamId immutability — a coach cannot
      // move a player to a different team by changing request.resource.data.teamId.
      allow update: if isAdmin()
        || (
          isCoachOfTeam(get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data)
          && request.resource.data.teamId == resource.data.teamId
        )
        || (
          isManagerOfTeam(get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data)
          && request.resource.data.teamId == resource.data.teamId
        )
        // A player may update their own record (e.g. RSVP) but must never touch status fields
        || (request.auth != null
            && request.auth.uid == resource.data.linkedUid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['statusNote', 'statusReturnDate', 'statusUpdatedAt', 'status']));

      // Sensitive PII subcollection — restricted to coaches of the player's team and admins.
      // Stores: dateOfBirth, parentContact, parentContact2, emergencyContact.
      // SEC-49: replaced isCoach() with team-scoped isCoachOfTeam() check. Previously
      // any coach could read child DOB and parent/emergency contacts cross-team.
      // SEC-58: write rule uses the player doc (via playerId) to resolve teamId —
      // NOT request.resource.data.teamId. Using request.resource.data would allow
      // a rogue coach to poison the teamId field, giving themselves read access.
      match /sensitiveData/{doc} {
        allow read: if isAdmin()
          || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data);
        allow write: if isAdmin()
          || isCoachOfTeam(
               get(/databases/$(database)/documents/teams/
                 $(get(/databases/$(database)/documents/players/$(playerId)).data.teamId)
               ).data
             );
      }
    }

    // collectionGroup rule required for collectionGroup('sensitiveData') queries.
    // SEC-49: scoped to coaches of the specific team, not all coaches platform-wide.
    // SEC-58: collectionGroup write is locked to admin-only — all client writes go through
    // /players/{playerId}/sensitiveData/{doc} which enforces the player-doc teamId lookup.
    // The collectionGroup path cannot reference playerId, so write cannot be safely
    // team-scoped here without the double get() anchor.
    match /{path=**}/sensitiveData/{doc} {
      allow read: if isAdmin()
        || isCoachOfTeam(get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data);
      allow write: if isAdmin();
    }

    // Rate limit tracking written exclusively by Cloud Functions (Admin SDK).
    // Clients have no access.
    match /rateLimits/{doc} {
      allow read, write: if false;
    }

    match /events/{eventId} {
      // Draft schedule events are only visible to league managers, admins, and coaches.
      // Published and all other statuses are readable by any authenticated user.
      allow read: if request.auth != null && (
        resource.data.status != 'draft'
        || isAdmin() || isLeagueManager() || isCoach()
      );
      // SEC-15: League schedule events (those with a seasonId) must be created as
      // draft. The transition to 'scheduled' is handled exclusively by the
      // publishSchedule Cloud Function (Admin SDK), which enforces LM ownership.
      // Non-league events (practices, standalone games) may still be created as
      // 'scheduled' directly by coaches.
      allow create: if (isAdmin() || isCoach() || isLeagueManager())
        && (request.resource.data.status != 'scheduled'
            || !('seasonId' in request.resource.data));
      allow delete: if isAdmin() || isCoach() || isLeagueManager();
      // SEC-15: Clients may not transition league schedule events to 'scheduled' —
      // that is a server-only operation via publishSchedule.
      allow update: if (isAdmin() || isCoach() || isLeagueManager())
        && (request.resource.data.status != 'scheduled'
            || resource.data.status == 'scheduled'
            || !('seasonId' in resource.data))
        // Any authenticated user may sign up for snacks:
        //   - only snackSignups + updatedAt may change (key-level guard)
        //   - snackSignups must grow by exactly 1 (append-only; prevents array-wipe SEC-59)
        //   - draft events excluded to preserve SEC-15 status guard (SEC-60)
        || (request.auth != null
            && resource.data.status != 'draft'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['snackSignups', 'updatedAt'])
            && request.resource.data.snackSignups.size() == resource.data.get('snackSignups', []).size() + 1);

      // RSVP subcollection — any authenticated user may read all RSVPs;
      // each user may only write their own RSVP document (keyed by uid).
      match /rsvps/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }


    }

    match /opponents/{opponentId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin() || isCoach() || isLeagueManager();
      allow delete: if isAdmin() || isCoach();
    }

    match /leagues/{leagueId} {
      allow read: if request.auth != null;
      // Any authenticated user who self-assigns as manager can create a league.
      // Aligns with createLeagueAndBecomeManager CF which has no role gate.
      // SEC-28: coaches/LMs with role='coach' at the top-level field are covered by
      // the isManagerOfLeague() check on request.resource.data.managerIds.
      allow create: if isAdmin() || isLeagueManager()
        || (request.auth != null && isManagerOfLeague(request.resource.data));
      // Phase 2: use managerIds access list instead of profile.leagueId cross-doc read.
      // SEC-29: non-admin writes may not touch access-control fields (managerIds, managedBy).
      // Admins retain unrestricted write access.
      allow update: if isAdmin()
        || (
          isManagerOfLeague(resource.data)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['managerIds', 'managedBy'])
        );
      allow delete: if isAdmin();

      // Wizard draft — one per league, owned by the LM who created it.
      // Coaches and players have no access.
      match /wizardDraft/draft {
        allow read, write: if isAdmin()
          || (isLeagueManager() && isManagerOfLeagueById(leagueId));
      }

      // Availability collections — created/managed by LM; coaches read their own response only.
      match /availabilityCollections/{collectionId} {
        allow read: if isAdmin()
          || (isLeagueManager() && isManagerOfLeagueById(leagueId));
        allow create, update, delete: if isAdmin()
          || (isLeagueManager() && isManagerOfLeagueById(leagueId));

        // Coach responses — coaches read/write only their own; LM reads all.
        match /responses/{coachUid} {
          allow read: if isAdmin()
            || request.auth.uid == coachUid
            || (isLeagueManager() && isManagerOfLeagueById(leagueId));
          allow create, update: if request.auth != null
            && request.auth.uid == coachUid
            && request.resource.data.coachUid == request.auth.uid;
          allow delete: if isAdmin();
        }
      }

      // Schedule fixtures — client writes these when LM publishes from the wizard preview.
      match /fixtures/{fixtureId} {
        allow read: if request.auth != null;
        allow write: if isAdmin()
          || (isLeagueManager() && isManagerOfLeagueById(leagueId));
      }

      // Schedule draft (backlog: async generation storage).
      match /drafts/{draftId} {
        allow read, write: if isAdmin()
          || (isLeagueManager() && isManagerOfLeagueById(leagueId));
      }

      // Generation status — written only by Cloud Functions via Admin SDK.
      match /generationStatus/{doc} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Seasons — league managers can read/write; league members can read.
      match /seasons/{seasonId} {
        allow read: if request.auth != null && (
          isAdmin() || isLeagueManager() || isCoach()
          || getProfile().leagueId == leagueId
        );
        allow write: if isAdmin()
          || (isLeagueManager() && isManagerOfLeagueById(leagueId));

        // Standings subcollection — same access as the parent season.
        match /standings/{standingId} {
          allow read: if request.auth != null && (
            isAdmin() || isLeagueManager() || isCoach()
            || getProfile().leagueId == leagueId
          );
          allow write: if false; // written exclusively by Cloud Functions (Admin SDK)
        }

        // Schedule config subcollection — persisted wizard configurations.
        match /scheduleConfig/{configId} {
          allow read: if request.auth != null && (
            isAdmin() || isLeagueManager() || isCoach()
            || getProfile().leagueId == leagueId
          );
          allow write: if isAdmin()
            || (isLeagueManager() && isManagerOfLeagueById(leagueId));
        }
      }

      // Divisions — league managers can read/write; league members can read.
      match /divisions/{divisionId} {
        allow read: if request.auth != null && (
          isAdmin() || isLeagueManager() || isCoach()
          || getProfile().leagueId == leagueId
        );
        allow write: if isAdmin()
          || (isLeagueManager() && isManagerOfLeagueById(leagueId));
      }

      // Pending result submissions — written by callable function, readable by league managers/coaches.
      match /pendingResults/{eventId} {
        allow read: if request.auth != null && (isAdmin() || isLeagueManager() || isCoach());
        allow write: if false; // written exclusively by Cloud Functions (Admin SDK)
      }

      // Result disputes — written by callable function, readable by league managers.
      match /resultDisputes/{eventId} {
        allow read: if request.auth != null && (isAdmin() || isLeagueManager());
        allow write: if false; // written exclusively by Cloud Functions (Admin SDK)
      }

      // League venue pool — LMs manage their own league's venue list; all auth'd users read.
      // Venues are copied from the LM's personal venue library (copy-based import).
      match /venues/{venueId} {
        allow read: if request.auth != null;
        // SEC-34: isLeagueManager() checks the legacy `role` field which
        // assignScopedRole never sets — co-managers added via scoped role
        // assignment were blocked. Use isManagerOfLeagueById() alone, which
        // checks managerIds[] and managedBy on the league doc.
        allow create: if isAdmin() || isManagerOfLeagueById(leagueId);
        allow update: if isAdmin() || isManagerOfLeagueById(leagueId);
        allow delete: if isAdmin() || isManagerOfLeagueById(leagueId);
      }
    }

    // Invite records — written and deleted exclusively by Cloud Functions (Admin SDK).
    // Coaches, admins, and league managers may list invites (to display on the Invites tab).
    // Invitees may read their own invite by matching email claim (used during signup).
    match /invites/{inviteId} {
      allow read: if request.auth != null && (
        isAdmin() || isCoach() || isLeagueManager() ||
        request.auth.token.email == resource.data.email
      );
      allow write: if false;
    }

    // System config — read by unauthenticated clients (e.g. pre-signup allowlist check),
    // written exclusively via Admin SDK (Cloud Functions / console).
    match /system/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Direct message threads — participants only.
    // threadId = sorted UIDs joined by underscore (e.g. "uid1_uid2").
    match /dmThreads/{threadId} {
      // Only existing participants may read thread metadata.
      allow read: if request.auth != null
        && resource.data.participants.hasAny([request.auth.uid]);

      // Create: caller must be one of exactly two participants in the incoming data.
      allow create: if request.auth != null
        && request.resource.data.participants.hasAny([request.auth.uid])
        && request.resource.data.participants.size() == 2;

      // SEC-63: Update locks participants to the existing list to prevent injection.
      // Only lastMessage/lastMessageAt/updatedAt/participantNames may change.
      allow update: if request.auth != null
        && resource.data.participants.hasAny([request.auth.uid])
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['lastMessage', 'lastMessageAt', 'updatedAt', 'participantNames']);

      match /messages/{messageId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participants.hasAny([request.auth.uid]);

        // SEC-65: text capped at 2000 chars; threadId pinned to path param to prevent cross-thread injection.
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.threadId == threadId
          && request.resource.data.keys().hasAll(['threadId', 'senderId', 'senderName', 'text', 'createdAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000
          && get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participants.hasAny([request.auth.uid]);

        // Message delete: admins only. Senders cannot hard-delete on a youth platform
        // (preserves audit trail; reviewable by admins for safety).
        // SEC-68: intentional — coaches/admins can see and remove inappropriate content.
        allow delete: if isAdmin();
      }
    }
  }
}
