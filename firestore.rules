rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function role() { return getProfile().role; }
    function isAdmin() { return role() == 'admin'; }
    function isCoach() { return role() == 'coach'; }
    function isLeagueManager() { return role() == 'league_manager'; }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == uid || isAdmin();
      allow update: if request.auth.uid == uid
        || isAdmin()
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teamId']) &&
          exists(/databases/$(database)/documents/teams/$(request.resource.data.teamId)) &&
          (get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.createdBy == request.auth.uid ||
           get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.coachId == request.auth.uid)
        );
      allow delete: if isAdmin();

      match /notifications/{notifId} {
        allow read, write: if request.auth.uid == uid;
      }
      match /config/{doc} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || request.auth.uid == resource.data.createdBy
        || request.auth.uid == resource.data.coachId
        || (isLeagueManager() && resource.data.leagueId == getProfile().leagueId);

      match /joinRequests/{requestUid} {
        allow create: if request.auth.uid == requestUid;
        allow read: if request.auth.uid == requestUid
          || isAdmin()
          || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
          || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.coachId;
        allow update: if isAdmin()
          || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
          || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.coachId;
      }
    }

    match /players/{playerId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin() || isCoach();
      allow update: if isAdmin() || isCoach();
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin() || isCoach() || isLeagueManager();
      allow update: if isAdmin() || isCoach() || isLeagueManager();
    }

    match /opponents/{opponentId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin() || isCoach() || isLeagueManager();
      allow delete: if isAdmin() || isCoach();
    }

    match /leagues/{leagueId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin()
        || (isLeagueManager() && getProfile().leagueId == leagueId);
      allow delete: if isAdmin();
    }

    // Invite records — written by Cloud Function (admin SDK), read by invitee only
    match /invites/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }
  }
}
