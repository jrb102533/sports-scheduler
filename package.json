{
  "name": "sports-scheduler",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "concurrently --kill-others-on-fail --names emulator,vite --prefix-colors blue,green \"npm run emulator\" \"npm run dev\"",
    "dev:emulator": "vite --mode emulator",
    "emulator": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "emulator:ci": "firebase emulators:start --import=./emulator-data --project=first-whistle-e76f4",
    "build": "tsc -b && vite build",
    "build:staging": "tsc -b && vite build --mode staging",
    "build:test": "tsc -b && vite build --mode test",
    "build:emulator": "tsc -b && vite build --mode emulator",
    "deploy:staging": "npm run build:staging && node scripts/check-staging-build.mjs && firebase deploy --only functions,hosting --project staging",
    "deploy:staging:hosting": "npm run build:staging && node scripts/check-staging-build.mjs && firebase deploy --only hosting --project staging",
    "deploy:production": "npm run build && firebase deploy --only functions,hosting --project production",
    "deploy:test": "npm run build:test && firebase deploy --project test",
    "lint": "eslint .",
    "lint:zustand-deps": "node scripts/lint-zustand-deps.js",
    "lint:zustand": "node scripts/lint-zustand-deps.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod": "E2E_BASE_URL=https://firstwhistlesports.com playwright test --project=production",
    "test:e2e:staging": "playwright test --project=staging",
    "test:e2e:emulator": "playwright test --project=emulator",
    "test:e2e:report": "playwright show-report",
    "kill-stale-browsers": "bash scripts/kill-stale-browsers.sh"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "firebase": "^12.12.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.0"
  }
}
