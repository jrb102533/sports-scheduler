# Environment configuration
# Copy the relevant block below into the appropriate .local file (gitignored)
#
# Environments:
#   dev  → .env.local             (npm run dev → localhost)
#   test → .env.test.local        (npm run deploy:test → first-whistle-e76f4.web.app)
#   prod → .env.production.local  (npm run deploy:prod → TBD)
#
# Firebase console: https://console.firebase.google.com

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Feature flags (default off — set to 'true' to enable)
VITE_FEATURE_SMS=false

# ── Cloud Function secrets (set via Firebase CLI, not .env files) ────────────
# firebase functions:secrets:set SMTP_HOST --project <alias>
# firebase functions:secrets:set SMTP_PORT       (e.g. 587 for TLS, 465 for SSL)
# firebase functions:secrets:set SMTP_USER
# firebase functions:secrets:set SMTP_PASS
# firebase functions:secrets:set EMAIL_FROM      (e.g. "First Whistle <no-reply@yourdomain.com>")
#
# SMS (only needed when VITE_FEATURE_SMS=true):
# firebase functions:secrets:set TWILIO_ACCOUNT_SID --project <alias>
# firebase functions:secrets:set TWILIO_AUTH_TOKEN
# firebase functions:secrets:set TWILIO_FROM_NUMBER
